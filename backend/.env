# Django Settings
SECRET_KEY=django-insecure-dev-key-change-in-production-abc123xyz
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Leave DATABASE_URL empty to use SQLite locally
# For Neon PostgreSQL, set: postgres://user:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# CORS — Frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ERP Integration
ERP_API_URL=https://your-erp-api.com/api/orders
ERP_API_KEY=your-erp-api-key

# Razorpay (for future integration)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
