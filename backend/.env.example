# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Neon PostgreSQL Database
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URL=postgres://user:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require

# CORS — Frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ERP Integration
ERP_API_URL=https://your-erp-api.com/api/orders
ERP_API_KEY=your-erp-api-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Frontend (for OAuth redirect)
FRONTEND_URL=http://localhost:5173
