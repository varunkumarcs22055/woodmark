# Production build env (Vite). Used by `npm run build` / Vercel.
# VITE_API_BASE_URL must point at the live backend with the trailing /api.
# Update the host below to your actual Render service URL once deployed.
VITE_API_BASE_URL=https://woodmark-backend.onrender.com/api
VITE_RAZORPAY_ENABLED=true
