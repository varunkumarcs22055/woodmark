# Copy this file's keys into Vercel → Project Settings → Environment Variables.
# Do NOT commit a populated copy; .env.production is gitignored.

# Where Vite sends API requests. Must include the trailing /api path
# (without it, every endpoint will 404 since the backend mounts at /api/).
# Example:  https://furnishop-backend.onrender.com/api
VITE_API_BASE_URL=https://YOUR-RENDER-SERVICE.onrender.com/api

# Razorpay integration. Leave 'false' (or unset) to use the simulated
# payment endpoint, which is fine until you have live Razorpay keys.
VITE_RAZORPAY_ENABLED=false
